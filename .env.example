APP_ENV=development
HTTP_ADDR=:8080
WEB_ORIGIN=http://localhost:5173
DEV_AUTH=true
# Railway private PostgreSQL connection string. Never expose with VITE_ prefix.
DATABASE_URL=
SUPABASE_URL=https://ftmlytoapegpvxbklkyg.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET=p2b-private
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
